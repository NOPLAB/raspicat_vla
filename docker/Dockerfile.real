# Dockerfile.real — raspicat real-robot edge stack.
#
# Bundles:
#  - ROS2 Humble ros-base (no Gazebo; raspicat hardware doesn't need a GUI).
#  - rt-net raspicat real-robot packages (raspicat_ros, raspicat_description,
#    raspicat_slam_navigation), fetched via vcstool from raspicat.repos and
#    pre-built in /opt/real_ws.
#  - CPU torch 2.2 + efficientnet_pytorch + grpcio so the edge node can run
#    AsyncVLA's Edge_adapter on the robot.
#  - external/AsyncVLA prismatic source vendored at /opt/AsyncVLA/prismatic
#    with the heavy training-time __init__ chain stubbed (same shim as
#    Dockerfile.sim).
#  - external/MBRA on PYTHONPATH for vint_train.models.vint.self_attention.
#
# Used by docker/run.sh `run {asyncvla,omnivla} --real --host HOST[:PORT]`.
# Mount the repo at /workspace; raspicat-vla packages build on first launch.
FROM ros:humble-ros-base

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
SHELL ["/bin/bash", "-c"]

# --------------------------------------------------------------- system deps
RUN apt-get update && apt-get install -y --no-install-recommends \
        bash-completion \
        curl \
        git \
        python3-pip \
        python3-pytest \
        python3-numpy \
        python3-opencv \
        python3-pil \
        python3-typing-extensions \
        python3-colcon-common-extensions \
        python3-rosdep \
        python3-vcstool \
        ros-humble-cv-bridge \
        ros-humble-diagnostic-msgs \
        ros-humble-lifecycle-msgs \
        sudo \
        vim \
        wget \
    && rm -rf /var/lib/apt/lists/*

# --------------------------------------------------------------- python deps
# CPU-only torch — the raspicat hardware doesn't have a GPU; AsyncVLA's
# Edge_adapter (~76M params) runs comfortably on the host CPU.
RUN pip3 install --no-cache-dir \
        --index-url https://download.pytorch.org/whl/cpu \
        'torch==2.2.0' 'torchvision==0.17.0' \
    && pip3 install --no-cache-dir \
        'numpy<2' \
        'efficientnet_pytorch>=0.7.1' \
        'einops' \
        'opencv-python-headless' \
        'grpcio>=1.50' \
        'grpcio-tools>=1.50' \
        'protobuf>=4.21'

# --------------------------------------------- OmniVLA-edge (Plan 2B Path 2) deps
# The omnivla_edge_local adapter runs the full OmniVLA-edge policy + CLIP ViT-B/32
# on the edge. CLIP is installed --no-deps so it can't downgrade the pinned torch;
# ftfy/regex/tqdm are CLIP's runtime deps. NOTE: the vendored OmniVLA_edge forward
# pass is GPU-only (uses tensor.get_device()), so Path 2 requires a CUDA-capable
# edge (e.g. Jetson). On such hardware, replace the CPU torch wheel above with the
# matching CUDA build. Path 1 (adapter_kind=omnivla) and asyncvla are unaffected.
RUN pip3 install --no-cache-dir 'ftfy' 'regex' 'tqdm' \
    && pip3 install --no-cache-dir --no-deps 'git+https://github.com/openai/CLIP.git'

# Pin setuptools to the ROS2 Humble default. colcon's `--symlink-install` runs
# `setup.py develop --editable` for ament_python packages (raspicat_vla_proto/
# remote/edge), which setuptools>=80 has removed; and setuptools>=66 paired with
# Ubuntu's apt packaging 21.3 breaks ament_cmake_python egg builds via
# `canonicalize_version(strip_trailing_zero=...)`. 59.6.0 avoids both. Keep this
# AFTER the torch/grpcio installs so it wins as the final setuptools.
RUN pip3 install --no-cache-dir 'setuptools==59.6.0'

# --------------------------------------------- rt-net raspicat real workspace
# Build the rt-net packages once at image build time so the robot launch
# graph is ready out-of-the-box. Sources are fetched from GitHub via vcstool
# using the pinned commits in raspicat.repos. raspicat_sim is then deleted
# from the workspace because Gazebo is not used on the hardware (and pulling
# it in would force ros-humble-gazebo-* into the image via rosdep).
COPY raspicat.repos /tmp/raspicat.repos
RUN mkdir -p /opt/real_ws/src \
    && vcs import /opt/real_ws/src < /tmp/raspicat.repos \
    && rm -rf /opt/real_ws/src/raspicat_sim /tmp/raspicat.repos

RUN apt-get update \
    && rosdep update \
    && rosdep install -r -y --from-paths /opt/real_ws/src --ignore-src --rosdistro humble \
    && rm -rf /var/lib/apt/lists/*

RUN cd /opt/real_ws \
    && source /opt/ros/humble/setup.bash \
    && colcon build --symlink-install --merge-install \
    && chmod -R a+rX /opt/real_ws

# --------------------------------------------- AsyncVLA edge inference deps
# Vendor only the prismatic source (training deps NOT installed). Stub every
# heavy __init__.py file so `from prismatic.models.small_head import
# Edge_adapter` and `from prismatic.vla.constants import ACTION_DIM` succeed
# without pulling transformers / draccus / peft.
COPY external/AsyncVLA/prismatic      /opt/AsyncVLA/prismatic
RUN : > /opt/AsyncVLA/prismatic/__init__.py \
    && : > /opt/AsyncVLA/prismatic/models/__init__.py \
    && : > /opt/AsyncVLA/prismatic/conf/__init__.py \
    && : > /opt/AsyncVLA/prismatic/vla/__init__.py \
    && chmod -R a+rX /opt/AsyncVLA

COPY external/MBRA                    /opt/MBRA
RUN chmod -R a+rX /opt/MBRA

ENV PYTHONPATH=/opt/AsyncVLA:/opt/MBRA/train

# --------------------------------------------- shell entry
RUN echo "source /opt/ros/humble/setup.bash" >> /etc/bash.bashrc \
    && echo "source /opt/real_ws/install/setup.bash" >> /etc/bash.bashrc \
    && echo '[[ -f /workspace/install/setup.bash ]] && source /workspace/install/setup.bash' >> /etc/bash.bashrc

WORKDIR /workspace
CMD ["/bin/bash"]
