# Dockerfile for AsyncVLA cloud-side gRPC server — Jetson AGX Orin (ARM64).
#
# ARM64/aarch64 counterpart of Dockerfile.asyncvla. The x86 CUDA wheels it pins
# (torch==2.2.0+cu121) do NOT exist for aarch64, so this image bases on NVIDIA's
# L4T JetPack image and pulls torch from the Jetson wheel index. See the header
# of Dockerfile.omnivla.jetson for the full JetPack -> base/index mapping and how
# to override the build args for your exact JetPack version.
#
# Like the x86 image, AsyncVLA's `prismatic.models.small_head` imports from
# `vint_train` (NHirose/Learning-to-Drive-Anywhere-with-MBRA). Initialise the
# submodule before building:
#   git submodule update --init --recursive external/MBRA external/AsyncVLA
ARG L4T_BASE=nvcr.io/nvidia/l4t-jetpack:r36.4.0
FROM ${L4T_BASE}

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
SHELL ["/bin/bash", "-c"]

# l4t-jetpack r36 is Ubuntu 22.04 with system Python 3.10 (matches the x86 image).
# libopenblas: the Jetson torch wheels link against libopenblas.so.0, which the
# l4t-jetpack base does not ship — without it `import torch` fails at C-ext load.
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip python3-dev python3-venv \
        libopenblas-dev \
        git curl ca-certificates build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3 /usr/bin/python

# Jetson torch wheels (aarch64, CUDA-enabled) from the jetson-ai-lab index.
# --index-url (not --extra-index-url) prevents pip from substituting PyPI's
# same-versioned generic wheel; devpi proxies upstream PyPI for torch's deps.
ARG TORCH_INDEX_URL=https://pypi.jetson-ai-lab.io/jp6/cu126
ARG TORCH_VERSION=2.8.0
ARG TORCHVISION_VERSION=0.23.0
ARG TORCHAUDIO_VERSION=2.8.0
RUN pip3 install --no-cache-dir --index-url "${TORCH_INDEX_URL}" \
        "torch==${TORCH_VERSION}" \
        "torchvision==${TORCHVISION_VERSION}" \
        "torchaudio==${TORCHAUDIO_VERSION}" \
    && python3 -c "import torch, torchvision; print('torch', torch.__version__, '/ torchvision', torchvision.__version__)"

# Inference deps (identical set to Dockerfile.asyncvla). transformers MUST be the
# openvla-oft fork. efficientnet_pytorch is required by Edge_adapter, which is
# imported transitively when the cloud backend loads prismatic.models.small_head.
RUN pip3 install --no-cache-dir \
        'numpy==1.26.4' \
        'huggingface_hub>=0.23' \
        'accelerate>=0.30' \
        'safetensors' \
        'sentencepiece==0.1.99' \
        'tokenizers==0.19.1' \
        'timm==0.9.10' \
        'peft==0.11.1' \
        'einops' \
        'efficientnet_pytorch>=0.7.1' \
        'PyYAML' \
        'Pillow' \
        'opencv-python-headless' \
        'utm' \
        'grpcio>=1.50' \
        'grpcio-tools>=1.50' \
        'protobuf>=4.21' \
        'typing_extensions>=4.5' \
    && pip3 install --no-cache-dir \
        'transformers @ git+https://github.com/moojink/transformers-openvla-oft.git'

# OPTIONAL: flash-attn (prebuilt aarch64 wheel available on the jetson index;
# SDPA fallback works at inference, so it stays off by default).

# Vendor AsyncVLA's `prismatic` on PYTHONPATH WITHOUT its training-time deps.
# Identical __init__.py blanking to Dockerfile.asyncvla (see that file for why).
COPY external/AsyncVLA /opt/AsyncVLA
RUN : > /opt/AsyncVLA/prismatic/__init__.py \
    && : > /opt/AsyncVLA/prismatic/models/__init__.py \
    && : > /opt/AsyncVLA/prismatic/conf/__init__.py \
    && : > /opt/AsyncVLA/prismatic/vla/__init__.py \
    && : > /opt/AsyncVLA/prismatic/training/__init__.py \
    && : > /opt/AsyncVLA/prismatic/models/backbones/llm/__init__.py

# Vendor MBRA's `vint_train` so prismatic.models.small_head can import
# MultiLayerDecoder_trans at module load time.
COPY external/MBRA /opt/MBRA
ENV PYTHONPATH=/opt/AsyncVLA:/opt/MBRA/train:$PYTHONPATH

WORKDIR /workspace
