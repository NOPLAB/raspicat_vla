# Dockerfile for OmniVLA cloud-side gRPC server — Jetson AGX Orin (ARM64).
#
# ARM64/aarch64 counterpart of Dockerfile.omnivla. The x86 CUDA wheels it
# pins (torch==2.2.0+cu121) do NOT exist for aarch64 on download.pytorch.org,
# so this image instead:
#   * bases on NVIDIA's L4T JetPack image (CUDA/cuDNN preinstalled), and
#   * pulls torch/torchvision/torchaudio from the Jetson wheel index
#     (pypi.jetson-ai-lab.io), which serves CUDA-enabled aarch64 builds.
#
# Match the base image + torch index to YOUR JetPack. Verify on the device:
#   cat /etc/nv_tegra_release      # -> L4T release (e.g. R36 (release), REVISION: 4.x)
#   nvcc --version                 # -> CUDA toolkit version
#
#   JetPack 6.1  -> L4T r36.4.0    CUDA 12.6  -> jp6/cu126   (this file's default)
#   JetPack 6.2  -> L4T r36.4.3    CUDA 12.6  -> jp6/cu126
#   JetPack 6.0  -> L4T r36.2/3    CUDA 12.2  -> see note below
#
# The jp6/cu126 index currently offers torch {2.8.0, 2.9.1, 2.10.0, 2.11.0};
# there is no 2.2.0 build for aarch64, so we default to the lowest compatible
# pair (torch 2.8.0 / torchvision 0.23.0 / torchaudio 2.8.0). Override any of
# these via --build-arg if your JetPack/index differs. For JetPack 6.0 (cu122),
# the jetson-ai-lab index no longer carries those wheels — use NVIDIA's redist
# (https://developer.download.nvidia.com/compute/redist/jp/v60/pytorch/, torch
# 2.4.0) by overriding TORCH_INDEX_URL/TORCH_VERSION, or upgrade to JetPack 6.1+.
ARG L4T_BASE=nvcr.io/nvidia/l4t-jetpack:r36.4.0
FROM ${L4T_BASE}

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
SHELL ["/bin/bash", "-c"]

# l4t-jetpack r36 is Ubuntu 22.04 with system Python 3.10 (matches the x86 image).
# libopenblas: the Jetson torch wheels link against libopenblas.so.0, which the
# l4t-jetpack base does not ship — without it `import torch` fails at C-ext load.
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip python3-dev python3-venv \
        libopenblas-dev \
        git curl ca-certificates build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3 /usr/bin/python

# Jetson torch wheels (aarch64, CUDA-enabled) come from the jetson-ai-lab index,
# NOT download.pytorch.org. Use --index-url (not --extra-index-url) so pip cannot
# silently substitute PyPI's same-versioned generic aarch64 wheel; the devpi
# index proxies upstream PyPI for torch's own dependencies.
ARG TORCH_INDEX_URL=https://pypi.jetson-ai-lab.io/jp6/cu126
ARG TORCH_VERSION=2.8.0
ARG TORCHVISION_VERSION=0.23.0
ARG TORCHAUDIO_VERSION=2.8.0
RUN pip3 install --no-cache-dir --index-url "${TORCH_INDEX_URL}" \
        "torch==${TORCH_VERSION}" \
        "torchvision==${TORCHVISION_VERSION}" \
        "torchaudio==${TORCHAUDIO_VERSION}" \
    && python3 -c "import torch, torchvision; print('torch', torch.__version__, '/ torchvision', torchvision.__version__)"

# Inference-only deps (identical set to Dockerfile.omnivla). transformers MUST be
# the openvla-oft fork (bidirectional attention). numpy<2 keeps prismatic happy.
RUN pip3 install --no-cache-dir \
        'numpy==1.26.4' \
        'huggingface_hub>=0.23' \
        'accelerate>=0.30' \
        'safetensors' \
        'sentencepiece==0.1.99' \
        'tokenizers==0.19.1' \
        'timm==0.9.10' \
        'peft==0.11.1' \
        'einops' \
        'Pillow' \
        'opencv-python-headless' \
        'utm' \
        'PyYAML' \
        'grpcio>=1.50' \
        'grpcio-tools>=1.50' \
        'protobuf>=4.21' \
        'typing_extensions>=4.5' \
    && pip3 install --no-cache-dir \
        'transformers @ git+https://github.com/moojink/transformers-openvla-oft.git'

# OPTIONAL: flash-attn. The jetson-ai-lab index ships a prebuilt aarch64 wheel
# (flash-attn 2.8.3 for jp6/cu126), so unlike the x86 image you can enable it
# without a slow source build. OpenVLAForActionPrediction runs without it at
# inference (PyTorch SDPA fallback); uncomment if attention is the bottleneck.
# RUN pip3 install --no-cache-dir --index-url "${TORCH_INDEX_URL}" 'flash-attn==2.8.3'

# --------------------------------------------- OmniVLA-edge (Plan 2B Path 3) deps
# The omnivla_edge backend runs the full OmniVLA-edge policy + CLIP ViT-B/32 on
# this Jetson and streams waypoints to the Pi. efficientnet_pytorch is the obs
# encoder; CLIP is installed --no-deps so it can't swap the CUDA-enabled Jetson
# torch wheel for a generic one, with ftfy/regex/tqdm its runtime deps.
# setuptools 59.6.0 keeps CLIP's legacy setup.py from tripping on newer setuptools.
# Not needed by Path 1 (--backend omnivla) but harmless there.
RUN pip3 install --no-cache-dir --no-deps 'efficientnet_pytorch>=0.7.1' \
    && pip3 install --no-cache-dir 'setuptools==59.6.0' wheel \
    && pip3 install --no-cache-dir 'ftfy' 'regex' 'tqdm' \
    && pip3 install --no-cache-dir --no-deps --no-build-isolation 'git+https://github.com/openai/CLIP.git'

# Vendor OmniVLA's `prismatic` package on PYTHONPATH WITHOUT pulling its
# training-time deps. Identical treatment to Dockerfile.omnivla (see that file
# for why each __init__.py is blanked).
COPY external/OmniVLA /opt/OmniVLA
RUN : > /opt/OmniVLA/prismatic/__init__.py \
    && : > /opt/OmniVLA/prismatic/models/__init__.py \
    && : > /opt/OmniVLA/prismatic/vla/__init__.py \
    && : > /opt/OmniVLA/prismatic/models/backbones/llm/__init__.py \
    && : > /opt/OmniVLA/prismatic/training/__init__.py
ENV PYTHONPATH=/opt/OmniVLA

WORKDIR /workspace
