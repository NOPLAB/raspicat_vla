# Dockerfile for OmniVLA cloud-side gRPC server (Plan 2B Path 1).
#
# Hosts the OpenVLA-OFT backbone (omnivla-original) on a CUDA GPU.
# Path 1 keeps no learned model on the edge, so this image only needs the
# inference path of `prismatic` (vendored at external/OmniVLA), not the
# training-time deps (tensorflow / lerobot / dlimp etc.).
FROM nvidia/cuda:12.2.2-cudnn8-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
SHELL ["/bin/bash", "-c"]

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.10 python3.10-venv python3-pip \
        git curl ca-certificates build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3.10 /usr/bin/python3 \
    && ln -sf /usr/bin/python3 /usr/bin/python

# Pin torch to the exact bf16 CUDA 12.1 wheels OmniVLA was trained against.
RUN pip3 install --no-cache-dir \
        'torch==2.2.0+cu121' 'torchvision==0.17.0+cu121' 'torchaudio==2.2.0+cu121' \
        --extra-index-url https://download.pytorch.org/whl/cu121

# Inference-only deps. transformers MUST be the openvla-oft fork
# (bidirectional attention). numpy<2 keeps prismatic happy.
RUN pip3 install --no-cache-dir \
        'numpy==1.26.4' \
        'huggingface_hub>=0.23' \
        'accelerate>=0.30' \
        'safetensors' \
        'sentencepiece==0.1.99' \
        'tokenizers==0.19.1' \
        'timm==0.9.10' \
        'peft==0.11.1' \
        'einops' \
        'Pillow' \
        'opencv-python-headless' \
        'utm' \
        'PyYAML' \
        'grpcio>=1.50' \
        'grpcio-tools>=1.50' \
        'protobuf>=4.21' \
        'typing_extensions>=4.5' \
    && pip3 install --no-cache-dir \
        'transformers @ git+https://github.com/moojink/transformers-openvla-oft.git'

# OPTIONAL: flash-attn. OpenVLAForActionPrediction_MMNv1 runs without it at
# inference (PyTorch SDPA is the fallback). Build is slow + toolchain-sensitive,
# so it is intentionally omitted from this image. Uncomment if benchmarks show
# attention to be the bottleneck.
# RUN pip3 install --no-cache-dir packaging ninja \
#     && pip3 install --no-cache-dir 'flash-attn==2.5.5' --no-build-isolation

# --------------------------------------------- OmniVLA-edge (Plan 2B Path 3) deps
# The omnivla_edge backend runs the full OmniVLA-edge policy + CLIP ViT-B/32 on
# this (remote/Jetson) box and streams waypoints to the Pi. efficientnet_pytorch
# is the obs encoder; CLIP is installed --no-deps so it can't touch the pinned
# torch, with ftfy/regex/tqdm its runtime deps. setuptools 59.6.0 keeps CLIP's
# legacy setup.py from tripping canonicalize_version on newer setuptools.
# Not needed by Path 1 (--backend omnivla) but harmless there.
RUN pip3 install --no-cache-dir --no-deps 'efficientnet_pytorch>=0.7.1' \
    && pip3 install --no-cache-dir 'setuptools==59.6.0' wheel \
    && pip3 install --no-cache-dir 'ftfy' 'regex' 'tqdm' \
    && pip3 install --no-cache-dir --no-deps --no-build-isolation 'git+https://github.com/openai/CLIP.git'

# Vendor OmniVLA's `prismatic` package WITHOUT pulling its training-time deps
# (tensorflow / dlimp / draccus / wandb / json-numpy / etc.). Several `__init__.py`
# files re-export training-only modules; we blank those so submodule imports the
# inference path actually uses (prismatic.extern.hf, prismatic.models.{action_heads,
# projectors,backbones.llm.prompting}, prismatic.vla.{action_tokenizer,constants})
# don't transitively pull missing deps. Reach the package via PYTHONPATH; the
# upstream pyproject.toml's PEP 621 metadata isn't compatible with the system
# pip's setuptools build, so a proper pip install yields an `UNKNOWN` package.
COPY external/OmniVLA /opt/OmniVLA
RUN : > /opt/OmniVLA/prismatic/__init__.py \
    && : > /opt/OmniVLA/prismatic/models/__init__.py \
    && : > /opt/OmniVLA/prismatic/vla/__init__.py \
    && : > /opt/OmniVLA/prismatic/models/backbones/llm/__init__.py \
    && : > /opt/OmniVLA/prismatic/training/__init__.py
ENV PYTHONPATH=/opt/OmniVLA

WORKDIR /workspace
